div.ajax_display.d55m_show {display:block;}
table.ajax_display.d55m_show {display:table;}
.ajax_display.multiColumnDisplay.d55m_show {display:inline-block;}
.multiLineDisplay TABLE.d55m0 {border-collapse:collapse;margin-bottom:2px}
.multiLineDisplay TD.d55m1 {margin:0px;padding:0px}
.multiLineDisplay TABLE.d55m2 {border-collapse:separate;border-spacing:0px;table-layout:fixed;width:783px}
.multiLineDisplay TD.d55m3 {margin:0px;overflow:hidden;width:6px}
.multiLineDisplay TD.d55m4 {margin:0px;overflow:hidden;width:777px}