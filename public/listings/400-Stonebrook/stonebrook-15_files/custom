/* =========== DEFAULT CSS UPDATE START=========== */

/* ---------- Global START ---------- */

:root {
    --mtrx-primary: #2471a8;
    --mtrx-primary-dark: #003c66;

    --mtrx-primary-two: var(--mtrx-secondary); /* Speed Bar */
    --mtrx-primary-two-text: var(--mtrx-dark);  /* Speed Bar Text*/

    --mtrx-primary-three: var(--mtrx-secondary); /* Widgets */
    --mtrx-primary-three-text: var(--mtrx-dark);  /* Widget Text */

    --mtrx-secondary: #e6e6e6;

    --mtrx-primary-four: #2471a8; /* Buttons */
    --mtrx-primary-four-text: var(--mtrx-light); /* Button Text */

    --mtrx-primary-five: var(--mtrx-primary);  /* Navbar */
    --mtrx-primary-five-text: var(--mtrx-light);   /* Navbar Text */

    --mtrx-light: #fff;
    --mtrx-dark: #000;

    --mtrx-info: #0d3759; /* info */
    --mtrx-danger: #ad1f2d; /* danger  */

    --mtrx-primary-gradient: linear-gradient(90deg, var(--mtrx-primary-dark) 0%, var(--mtrx-primary) 100%);
    --mtrx-primary-gradient--vertical: linear-gradient(180deg, var(--mtrx-primary-dark) 0%, var(--mtrx-primary) 100%);
}



    #m_uc_m_lblAdditionError { /* Additional Fields Duplication Info Message */
        color: #fff !important;
        font-weight: normal !important;
        padding: 10px;
        border: 1px #0b3252 solid;
        display: block;
        margin: 10px 0px;
        background: var(--mtrx-info);
        line-height: 18px;
    }



    /* Help Popup START */

    #helpHeader { 
        height: 56px !important;
        padding: 1rem 1rem !important;
        background: var(--mtrx-primary-gradient) !important;
    }

    #helpContentWrapper {
        top: 56px !important;
    }

    /* Help Popup END */


/* ---------- Global END ---------- */




/* ---------- Navbar START ---------- */


.TopMenuInner {
    background: var(--mtrx-primary-gradient--vertical);
}


    .TopMenuLeft {
        width: 1px;
        position: relative;
        top: 3px;
    }

    .TopMenuLeft img{ /* adjust size and position of logo */
        margin-left:12px;
    }

    td.TopMenuLeft ~ td { /* adjust vertical position of sibling cells */
        position:relative;
        top:3px;
    }

    td.TopMenuLeft + td { /* adjust position of TopMenuLeft sibling cell */
        padding-left: 2.2rem;
    }




    /* Menu START */

    .sf-menu ul li:active { /* highlight sub menu item when clicked */
        background: var(--mtrx-primary-four);
        color: var(--mtrx-primary-four-text); /* used when item is not a link (ie selected language */
    }

    .sf-menu ul li:active > a { /* sub menu item link color when clicked */
        color: var(--mtrx-primary-four-text);
    }

    /* Menu END*/



    /* Notification START */

    .mtx-dropdown--withHeader .dropdown-header {
        background-color: var(--mtrx-primary);
    }

    .mtx-dropdown--withHeader .dropdown-item:hover,     .mtx-dropdown--withHeader .dropdown-item:active { /* highlight notification item on hover and selected */
        background: #e6e6e6; 
    }

    /* Notification END */




/* ---------- Navbar END ---------- */




/* ---------- Speed Bar START ---------- */


.mtx-speedbar .input-group-addon { /* remove background under Other Criteria */
    background-color: transparent; 
}


.mtx-speedbar-search .fa-search:before {  /* speed bar search icon */
    font-weight: normal;
}


/* ---------- Speed Bar END ---------- */




/* ---------- Recent Search START ---------- */

        /* recent search slideout START */

        .mtx-blade .modal-header { /* recent search header */
            background-image: var(--mtrx-primary-gradient);
            color: var(--mtrx-light);
        }


        .modal-header .close {
            color: var(--mtrx-light);
            text-shadow: 0 0px 0 #fff;
            filter: alpha(opacity=30);
            opacity: .3;
        }

        .recentSearchRow {
            border-color: var(--mtrx-primary) !important;
        }

        .recentSearchRow:hover, .recentSearchRow:hover .text-muted {
            background: var(--mtrx-primary) !important;
            color: var(--mtrx-light) !important;
        }

        .recentSearchRow:hover .recentSearchCountType {
            color: var(--mtrx-light) !important;
        }

        /* recent search slideout END */


/* ---------- Recent Search END ---------- */





/* ---------- Widgets START ---------- */



/* News Widget START */

.mtx-btn-confirm, .mtx-btn-confirm:hover, .mtx-btn-confirm:focus, .mtx-btn-confirm:active, .open>.dropdown-toggle.mtx-btn-confirm {
    background-color: var(--mtrx-primary-four);
    border-color: var(--mtrx-primary-four);
}

/* News Widget END */




.css_container .wgt_heading {
    background: var(--mtrx-secondary);
    border-bottom: 1px solid #fcfcfc;
    padding-left:2px;
    color: var(--mtrx-dark);
}


.css_container .wgt_heading:hover {
    background: var(--mtrx-secondary);
    border-bottom: 1px solid #f0f0f0;
    color: var(--mtrx-dark);
}


.css_container .wgt_heading a, .css_container .wgt_heading:hover a, .css_container .wgt_heading:hover a:hover, .wgt_manager .css_container:hover .wgt_heading a {
    color: var(--mtrx-dark); /* link in heading - my listings - */
}


/* ---------- Widgets END ---------- */




/* ---------- Page Buttons START ---------- */


.adminButtonCritical {
    background: var(--mtrx-danger);
    cursor: pointer;
    color: #fff;
    border: none;
    padding: 4px 9px 4px 9px;
    margin-top: 5px;
}



.adminButton, .adminButton2 {
    background: var(--mtrx-primary-four);
    border-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
    border: none;
    padding: 4px 10px;
    margin-top: 5px;
}


.adminButton:hover, .adminButton2:hover {
    background-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
}



    /* New Search Button START */

    .switchTo3PanelSearch { /* v11 */
        padding: 10px;
        border-radius: 3px;
        line-height: 34px;
    }

    a.switchTo3PanelSearch { /* v11 */
        text-decoration: none;
    }

    /* New Search Button END */


/* ---------- Page Buttons END ---------- */




/* ---------- Button Bar START ---------- */



.btn-primary { /* primary button color */
    background-color: var(--mtrx-primary-four);
    border-color: var(--mtrx-primary-four);
}


.btn-primary:hover {
    background-color: var(--mtrx-primary-four);
    border-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
}


.btn-primary:active, .btn-primary.active, .open>.dropdown-toggle.btn-primary { 
    background-color: var(--mtrx-primary-four) !important;
    border-color: var(--mtrx-primary-four) !important;
}


.btn-primary:focus, .btn-primary.focus {
    background-color: var(--mtrx-primary-four) !important;
    border-color: var(--mtrx-primary-four) !important;
}


    /* BB Main Menu START */

    div.tabbedMenu ul.mainmenu li.selected, div.tabbedMenu ul.mainmenu li.selected:hover {
        background-color: var(--mtrx-primary-four);
        border: solid 1px var(--mtrx-primary-four);
    }


    /* BB Main Menu END */



    /* Important START */

    .buttonBar TD.leftImportant.leftedge { /* Button Bar with main menu */
        background: var(--mtrx-primary-four);
    }

    .buttonBar TD.important {
        background: var(--mtrx-primary-four) !important;
    }

    .buttonBar TD.rightImportant {
        background: var(--mtrx-primary-four) !important;
    }


    .buttonBar TD.leftImportant { /* Button Bar without main menu */
        background: var(--mtrx-primary-four) !important;
    }


    /* Important END */



    /* Disabled START */

    .buttonBar TD.disabled { 
        background-color: var(--mtrx-primary-four) !important; /* disabled button color adjust */
        opacity: .5;
    }
    /* Disabled END */


/* ---------- Button Bar END ---------- */





/* ---------- Paging START ---------- */


div.tabbedMenu .pagingLinks .active a, table.tabbedMenu .pagingLinks .active a {
    background-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
}


/* ---------- Paging END ---------- */





/* ---------- Calendar START ---------- */



.cal_btn { /* calendar buttons */
    background-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
}

.cal_btnhov { /* calendar hovered buttons */
    background-color: var(--mtrx-primary-four);
    color: var(--mtrx-primary-four-text);
}


/* ---------- Calendar END ---------- */




