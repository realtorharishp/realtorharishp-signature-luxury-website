}

.S_ListBox_Rollout .lbx_ro_btn input:hover { /* cal_btn */
    background: var(--mtrx-primary-four); /* For browsers that do not support gradients */
    border: solid 1px var(--mtrx-primary-four);
}


/* ---------- (Search) Roll-out control END ---------- */




/* ---------- Wizard Step Button Bar START ---------- */


.stepButtonBar TD.selected {
    background-color: var(--mtrx-primary-four);
}


.stepButtonBar TD.left, .stepButtonBar TD.right {  /* remove border from end caps */
